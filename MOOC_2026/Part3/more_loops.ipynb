   "source": [
    "sum = 0\n",
    "\n",
    "while True:\n",
    "    number = int(input(\"Please type in a number , -1 to exit: \"))\n",
    "    if number == -1:\n",
    "        break\n",
    "    sum += number\n",
    "\n",
    "print(f\"The sum is {sum}\")"
   ]
